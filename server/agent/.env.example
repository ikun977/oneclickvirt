# oneclickvirt-agent 配置示例
# 复制此文件为 .env 并填写实际配置

# ===== 必填配置 =====

# API 认证令牌（所有 API 请求需在 x-token 头中携带此值）
API_TOKEN=change_this_to_a_strong_token

# ===== 可选配置 =====

# 流量采集方式：nft（默认，使用 nftables）或 ipt（使用 iptables）
# TRAFFIC_COLLECT_METHOD=nft

# 流量采集间隔（单位：秒，默认 5）
# TRAFFIC_COLLECT_INTERVAL=5

# 资源采集间隔（单位：秒，默认 30）
# RESOURCE_COLLECT_INTERVAL=30

# ===== 反向代理配置 =====

# 是否启用反向代理功能（默认 false）
# 设置为 true 时才会启动反向代理服务器，否则仅运行 API 服务器
ENABLE_REVERSE_PROXY=false

# HTTP 反向代理监听地址（可选，启用反向代理时生效）
# PROXY_HTTP_ADDR=0.0.0.0:80

# HTTPS 反向代理监听地址（可选，需同时配置证书）
# PROXY_HTTPS_ADDR=0.0.0.0:443

# TLS 证书文件路径（启用 HTTPS 时必填）
# PROXY_TLS_CERT=/path/to/cert.pem

# TLS 私钥文件路径（启用 HTTPS 时必填）
# PROXY_TLS_KEY=/path/to/key.pem

# ===== 其他配置 =====

# 额外排除的 IPv4 CIDR（逗号分隔，这些段的流量不计入统计）
EXTRA_EXCLUDE_CIDRS_V4=

# 额外排除的 IPv6 CIDR（逗号分隔）
EXTRA_EXCLUDE_CIDRS_V6=

# 日志级别（可选：error, warn, info, debug, trace）
# RUST_LOG=info

